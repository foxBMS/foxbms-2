from waflib.Build import POST_LAZY, BuildContext


def build(bld: BuildContext):
    if bld.variant == "docs":
        # C source code examples that should build
        if bld.env.CC:
            bld.recurse(
                [
                    "../tools/crc",
                    "developer-manual/style-guide/examples",
                    "developer-manual/style-guide/state-machine-example",
                    "software/modules/driver/can",
                    "software/modules/engine/database",
                    "software/modules/task/ftask",
                    "software/unit-tests",
                ],
            )
        # build the sphinx documentation
        config = bld.path.find_node("conf.py")
        bld(
            features="sphinx",
            builders="html",
            out_dir=".",
            conf_py=config,
            VERSION=bld.env.version,
            RELEASE=bld.env.version,
        )
        bld.post_mode = POST_LAZY

    elif "doxygen" in bld.variant:
        feature = "doxygen"
        common_input = {
            "doxygen_conf": "doxygen.conf.in",
            "project_number": f"{bld.env.APPNAME} {bld.env.VERSION}",
            "project_logo": "_static/foxbms250px.png",
            "layout_file": "doxygen_layout.xml",
            "image_path": "_static/cc.large.png",
            "html_footer": "doxygen_footer.html",
            "html_stylesheet": "style-sheet-file.css",
            "html_extra_files": "_static/cc.large.png",
            "dot_path": bld.env.DOT[0],
        }
        specific_input = {}
        base_name = '"%s Battery Management System %s API Documentation"'

        if bld.variant == "app_doxygen":
            specific_input = {
                "project_brief": base_name % (bld.env.APPNAME, "Application"),
                "project_name": f"{bld.env.APPNAME} Bootloader",
                "input": "developer-manual/style-guide/state-machine-example ../src/app",
                "exclude_patterns": "*/vendor/*",
            }
        elif bld.variant == "app_doxygen_unit_test":
            specific_input = {
                "project_brief": base_name % (bld.env.APPNAME, "Application Unit Test"),
                "project_name": f"{bld.env.APPNAME} Application",
                "input": "../src/app ../tests/unit/app",
                "exclude": "../src/app/doxygen_app.h",
                "exclude_patterns": "*/vendor/*",
                "predefined": "UNITY_UNIT_TEST=1",
            }
        elif bld.variant == "bootloader_doxygen":
            specific_input = {
                "project_brief": base_name % (bld.env.APPNAME, "Bootloader"),
                "project_name": f"{bld.env.APPNAME} Bootloader",
                "input": "../src/bootloader",
                "exclude_patterns": "*/vendor/*",
            }
        elif bld.variant == "bootloader_doxygen_unit_test":
            specific_input = {
                "project_brief": base_name % (bld.env.APPNAME, "Bootloader Unit Test"),
                "project_name": f"{bld.env.APPNAME} Bootloader",
                "input": "../src/bootloader ../tests/unit/bootloader",
                "exclude": "../src/bootloader/doxygen_bootloader.h",
                "exclude_patterns": "*/vendor/*",
                "predefined": "UNITY_UNIT_TEST=1",
            }
        bld(features=feature, **common_input, **specific_input)
