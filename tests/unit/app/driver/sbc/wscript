            bld.srcnode.find_node("src/app/driver/sbc/fs8x_driver/sbc_fs8x.h"),
            bld.srcnode.find_node(
                "src/app/driver/sbc/fs8x_driver/sbc_fs8x_communication.h"
            ),
            bld.srcnode.find_node("src/app/driver/spi/spi.h"),
        ],
    )
