from waflib.Build import BuildContext


def build(bld: BuildContext) -> None:
    bld(
        features="c cprogram test",
        source=[
            bld.srcnode.find_node("src/app/driver/sbc/nxpfs85xx.c"),
            bld.path.find_node("test_nxpfs85xx_mcu_spi_transfer_data.c"),
        ],
        target="test-app-nxpfs85xx_mcu_spi_transfer_data",
        includes=[
            bld.srcnode.find_node("src/app/driver/config"),
            bld.srcnode.find_node("src/app/driver/dma"),
            bld.srcnode.find_node("src/app/driver/fram"),
            bld.srcnode.find_node("src/app/driver/io"),
            bld.srcnode.find_node("src/app/driver/sbc"),
            bld.srcnode.find_node("src/app/driver/sbc/fs8x_driver"),
            bld.srcnode.find_node("src/app/driver/spi"),
            bld.srcnode.find_node("src/app/engine/diag"),
            bld.srcnode.find_node("src/app/engine/hw_info"),
        ],
        mocks=[
            bld.srcnode.find_node("src/app/engine/diag/diag.h"),
            bld.srcnode.find_node("src/app/driver/dma/dma.h"),
            bld.srcnode.find_node("src/app/main/include/fassert.h"),
