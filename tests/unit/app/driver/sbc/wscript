            bld.srcnode.find_node("src/app/engine/diag/diag.h"),
            bld.srcnode.find_node("src/app/driver/dma/dma.h"),
            bld.srcnode.find_node("src/app/main/include/fassert.h"),
            bld.srcnode.find_node("src/app/driver/fram/fram.h"),
            bld.srcnode.find_node("src/app/driver/io/io.h"),
            bld.srcnode.find_node("src/app/engine/hw_info/master_info.h"),
